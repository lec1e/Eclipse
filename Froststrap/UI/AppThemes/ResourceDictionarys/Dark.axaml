<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<SolidColorBrush x:Key="NewTextEditorBackground"       Color="#14121C" />
	<SolidColorBrush x:Key="NewTextEditorForeground"       Color="White" />
	<SolidColorBrush x:Key="NewTextEditorLink"             Color="#A855F7" />
	<SolidColorBrush x:Key="CompletionListBackgroundBrush" Color="#14121C" />

	<SolidColorBrush x:Key="PrimaryBackgroundColor"        Color="#CC0A0A0F" />
	<SolidColorBrush x:Key="NormalDarkAndLightBackground"  Color="#010A0A0F" />

	<SolidColorBrush x:Key="ApplicationBackgroundColor"    Color="#0A0A0F" />

	<SolidColorBrush x:Key="NotificationBackgroundColor"   Color="#14121C" />

	<SolidColorBrush x:Key="BrandAccentBrush"              Color="#A855F7" />
	<SolidColorBrush x:Key="BrandSurfaceBrush"             Color="#14121C" />
	<SolidColorBrush x:Key="BrandHairlineBrush"            Color="#2A2438" />
	<SolidColorBrush x:Key="BrandInkBrush"                 Color="#0A0A0F" />
	<SolidColorBrush x:Key="BrandPurpleBrush"              Color="#C084FC" />
</ResourceDictionary>
