<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             x:Class="Froststrap.UI.Elements.Settings.Pages.ToolsHubPage"
             x:DataType="vm:ToolsHubViewModel">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="16">
      <TextBlock Text="All tools" FontSize="28" FontWeight="Bold" />
      <TextBlock Text="Everything else lives here — pick a tool to open it."
                 Opacity="0.7" Margin="0,0,0,8" />
      <ItemsControl ItemsSource="{Binding Items}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ToolsHubItem">
            <Button Width="260" Height="88" Margin="0,0,12,12"
                    Padding="14" CornerRadius="14"
                    HorizontalContentAlignment="Left"
                    Background="#77100F18" BorderBrush="#33A78BFA" BorderThickness="1"
                    Command="{Binding $parent[UserControl].((vm:ToolsHubViewModel)DataContext).OpenToolCommand}"
                    CommandParameter="{Binding Tag}">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Border Width="40" Height="40" CornerRadius="12" Background="#447C3AED">
                  <ic:Lucide Icon="{Binding Icon}" Width="18" Height="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Subtitle}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
