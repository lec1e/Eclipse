<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             xmlns:alt="clr-namespace:Froststrap.UI.ViewModels.Settings.AltMan"
             xmlns:models="clr-namespace:Froststrap.Models"
             xmlns:acc="clr-namespace:Froststrap.Utility.Accounts"
             x:Class="Froststrap.UI.Elements.Settings.Pages.AltManPage"
             x:DataType="vm:AltManViewModel">
  <DockPanel Margin="10">
    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
      <TextBlock Text="AltMan" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="{Binding Accounts.ActiveSummary}" FontWeight="SemiBold" Opacity="0.85" />
    </StackPanel>

    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
      <!-- Accounts -->
      <TabItem Header="Accounts">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel Margin="8" Spacing="8" DataContext="{Binding Accounts}">
            <TextBlock Text="{Binding Description}" Opacity="0.7" TextWrapping="Wrap" FontSize="12" />
            <TextBlock Text="{Binding EncryptionInfo}" FontSize="11" Opacity="0.55" TextWrapping="Wrap" />

            <WrapPanel Orientation="Horizontal">
              <Button Content="WebView login" Classes="accent" Margin="0,0,8,8" Command="{Binding AddBrowserCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Content="Quick Sign-In" Margin="0,0,8,8" Command="{Binding AddQuickSignCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Content="Refresh selected" Margin="0,0,8,8" Command="{Binding RefreshStatusCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Content="Refresh all" Margin="0,0,8,8" Command="{Binding RefreshAllCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Content="Select all" Margin="0,0,8,8" Command="{Binding SelectAllCommand}" />
              <Button Content="Clear selection" Margin="0,0,8,8" Command="{Binding ClearSelectionCommand}" />
              <Button Content="Set default" Margin="0,0,8,8" Command="{Binding SetDefaultCommand}" />
              <Button Content="Favorite" Margin="0,0,8,8" Command="{Binding ToggleFavoriteCommand}" />
              <Button Content="Open with cookie" Margin="0,0,8,8" Command="{Binding OpenBrowserCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Content="Export cookies" Margin="0,0,8,8" Command="{Binding ExportCookiesCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Content="Kill Roblox" Margin="0,0,8,8" Command="{Binding KillRobloxCommand}" />
              <Button Content="Clear cache" Margin="0,0,8,8" Command="{Binding ClearCacheCommand}" />
              <Button Content="Delete" Margin="0,0,8,8" Command="{Binding DeleteSelectedCommand}" />
              <Button Content="Save notes" Margin="0,0,8,8" Command="{Binding SaveNotesCommand}" />
            </WrapPanel>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Watermark="Paste .ROBLOSECURITY cookie" Text="{Binding CookieInput}" />
              <Button Grid.Column="1" Content="Add cookie" Command="{Binding AddCookieCommand}" IsEnabled="{Binding IsIdle}" Classes="accent" />
            </Grid>

            <Grid ColumnDefinitions="*,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Watermark="Place ID" Text="{Binding JoinPlaceId}" />
              <TextBox Grid.Column="1" Watermark="Job ID / VIP" Text="{Binding JoinJobId}" />
              <Button Grid.Column="2" Content="Join" Command="{Binding JoinSelectedCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Grid.Column="3" Content="Join VIP" Command="{Binding JoinSelectedVipCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Grid.Column="4" Content="Join presence" Command="{Binding JoinPresenceCommand}" IsEnabled="{Binding IsIdle}" />
              <Button Grid.Column="5" Content="Fill presence" Command="{Binding FillJoinFromPresenceCommand}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Watermark="Follow User ID" Text="{Binding FollowUserId}" />
              <Button Grid.Column="1" Content="Follow" Command="{Binding FollowUserCommand}" IsEnabled="{Binding IsIdle}" />
              <CheckBox Grid.Column="2" Content="Kill on launch" IsChecked="{Binding KillRobloxOnLaunch}" VerticalAlignment="Center" />
              <CheckBox Grid.Column="3" Content="Clear cache on launch" IsChecked="{Binding ClearCacheOnLaunch}" VerticalAlignment="Center" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Watermark="Custom URL" Text="{Binding CustomUrl}" />
              <Button Grid.Column="1" Content="Open URL" Command="{Binding OpenCustomUrlCommand}" IsEnabled="{Binding IsIdle}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Watermark="Backup password" Text="{Binding BackupPassword}" PasswordChar="*" />
              <Button Grid.Column="1" Content="Export backup" Command="{Binding ExportBackupCommand}" />
              <Button Grid.Column="2" Content="Import latest" Command="{Binding ImportBackupCommand}" />
            </Grid>

            <Expander Header="Privacy settings" IsExpanded="False">
              <StackPanel Spacing="8" Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <ComboBox Grid.Column="0" ItemsSource="{Binding OnlineStatusOptions}" SelectedItem="{Binding OnlineStatusPrivacy}" />
                  <Button Grid.Column="1" Content="Set online" Command="{Binding ApplyOnlinePrivacyCommand}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <ComboBox Grid.Column="0" ItemsSource="{Binding JoinPrivacyOptions}" SelectedItem="{Binding JoinPrivacy}" />
                  <Button Grid.Column="1" Content="Set join" Command="{Binding ApplyJoinPrivacyCommand}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                  <ComboBox Grid.Column="0" ItemsSource="{Binding InventoryPrivacyOptions}" SelectedItem="{Binding InventoryPrivacy}" />
                  <Button Grid.Column="1" Content="Set inventory" Command="{Binding ApplyInventoryPrivacyCommand}" />
                </Grid>
              </StackPanel>
            </Expander>

            <TextBlock Text="{Binding Status}" Opacity="0.75" TextWrapping="Wrap" />

            <DataGrid ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                      AutoGenerateColumns="False" IsReadOnly="False" CanUserResizeColumns="True"
                      CanUserSortColumns="True" GridLinesVisibility="Horizontal"
                      MinHeight="240" Height="300"
                      x:Name="AccountsGrid">
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Copy Info">
                  <MenuItem Header="Display Name" Command="{Binding CopyDisplayNameCommand}" />
                  <MenuItem Header="Username" Command="{Binding CopyUsernameCommand}" />
                  <MenuItem Header="User ID" Command="{Binding CopyUserIdCommand}" />
                  <MenuItem Header="Cookie" Command="{Binding CopyCookieCommand}" />
                  <MenuItem Header="Launch Link" Command="{Binding CopyLaunchLinkCommand}" />
                  <MenuItem Header="Note" Command="{Binding CopyNoteCommand}" />
                </MenuItem>
                <MenuItem Header="Open in WebView">
                  <MenuItem Header="Home" Command="{Binding OpenHomeCommand}" />
                  <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}" />
                  <MenuItem Header="Profile" Command="{Binding OpenProfileCommand}" />
                  <MenuItem Header="Friends" Command="{Binding OpenFriendsCommand}" />
                  <MenuItem Header="Avatar" Command="{Binding OpenAvatarCommand}" />
                  <MenuItem Header="Inventory" Command="{Binding OpenInventoryCommand}" />
                  <MenuItem Header="Catalog" Command="{Binding OpenCatalogCommand}" />
                  <MenuItem Header="Custom URL…" Command="{Binding OpenCustomUrlCommand}" />
                </MenuItem>
                <MenuItem Header="Join">
                  <MenuItem Header="Join place" Command="{Binding JoinSelectedCommand}" />
                  <MenuItem Header="Join VIP" Command="{Binding JoinSelectedVipCommand}" />
                  <MenuItem Header="Join presence" Command="{Binding JoinPresenceCommand}" />
                  <MenuItem Header="Follow user" Command="{Binding FollowUserCommand}" />
                </MenuItem>
                <Separator />
                <MenuItem Header="Refresh" Command="{Binding RefreshStatusCommand}" />
                <MenuItem Header="Remove" Command="{Binding DeleteSelectedCommand}" />
              </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
              <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected}" Width="40" />
              <DataGridTextColumn Header="Display" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True" />
              <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" IsReadOnly="True" />
              <DataGridTextColumn Header="User ID" Binding="{Binding UserId}" Width="100" IsReadOnly="True" />
              <DataGridTextColumn Header="Age" Binding="{Binding AgeGroup}" Width="70" IsReadOnly="True" />
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" IsReadOnly="True" />
              <DataGridTextColumn Header="Voice" Binding="{Binding VoiceStatus}" Width="80" IsReadOnly="True" />
              <DataGridCheckBoxColumn Header="★" Binding="{Binding IsFavorite}" Width="40" />
              <DataGridTextColumn Header="Location" Binding="{Binding LastLocation}" Width="*" IsReadOnly="True" />
              <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="2*" />
            </DataGrid.Columns>
          </DataGrid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Friends -->
      <TabItem Header="Friends">
        <DockPanel Margin="8" DataContext="{Binding Friends}">
          <StackPanel DockPanel.Dock="Top" Spacing="8">
            <WrapPanel>
              <Button Content="Refresh" Classes="accent" Margin="0,0,8,8" Command="{Binding RefreshCommand}" />
              <TextBox Width="180" Margin="0,0,8,8" Watermark="Username or ID" Text="{Binding AddUsername}" />
              <Button Content="Add friend" Margin="0,0,8,8" Command="{Binding AddFriendCommand}" />
              <Button Content="Launch instance" Margin="0,0,8,8" Command="{Binding LaunchFriendCommand}" />
              <Button Content="Open profile" Margin="0,0,8,8" Command="{Binding OpenProfileCommand}" />
              <Button Content="Unfriend" Margin="0,0,8,8" Command="{Binding UnfriendCommand}" />
              <Button Content="Copy ID" Margin="0,0,8,8" Command="{Binding CopyUserIdCommand}" />
            </WrapPanel>
            <TextBlock Text="{Binding Status}" Opacity="0.75" />
          </StackPanel>
          <Grid ColumnDefinitions="2*,*,*" ColumnSpacing="8">
            <DataGrid Grid.Column="0" ItemsSource="{Binding Friends}" SelectedItem="{Binding SelectedFriend}"
                      AutoGenerateColumns="False" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Display" Binding="{Binding DisplayName}" Width="*" />
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*" />
                <DataGridTextColumn Header="Status" Binding="{Binding Presence}" Width="80" />
                <DataGridTextColumn Header="Location" Binding="{Binding LastLocation}" Width="*" />
              </DataGrid.Columns>
            </DataGrid>
            <DockPanel Grid.Column="1">
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="Requests" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="Load more" Command="{Binding LoadMoreRequestsCommand}" />
              </StackPanel>
              <ListBox ItemsSource="{Binding Requests}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="acc:RobloxFriendRequest">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                      <TextBlock Grid.Column="0" Text="{Binding DisplayName}" ToolTip.Tip="{Binding Username}" />
                      <Button Grid.Column="1" Content="Accept" Command="{Binding $parent[UserControl].((vm:AltManViewModel)DataContext).Friends.AcceptRequestCommand}" CommandParameter="{Binding}" />
                      <Button Grid.Column="2" Content="Decline" Command="{Binding $parent[UserControl].((vm:AltManViewModel)DataContext).Friends.DeclineRequestCommand}" CommandParameter="{Binding}" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </DockPanel>
            <StackPanel Grid.Column="2" Spacing="6">
              <TextBlock Text="Details" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Detail.DisplayName}" />
              <TextBlock Text="{Binding Detail.Username}" Opacity="0.7" />
              <TextBlock Text="{Binding Detail.Presence}" />
              <TextBlock Text="{Binding Detail.Description}" TextWrapping="Wrap" MaxHeight="160" TextTrimming="CharacterEllipsis" />
              <TextBlock Text="Friends lost" FontWeight="SemiBold" Margin="0,12,0,0" />
              <ListBox ItemsSource="{Binding FriendsLost}" MaxHeight="180">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="acc:RobloxFriendInfo">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Grid>
        </DockPanel>
      </TabItem>

      <!-- Games (includes servers + thumbnail for selection) -->
      <TabItem Header="Games">
        <DockPanel Margin="8" DataContext="{Binding Games}">
          <StackPanel DockPanel.Dock="Top" Spacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <TextBox Grid.Column="0" Watermark="Search games" Text="{Binding Query}" />
              <Button Grid.Column="1" Content="Search" Classes="accent" Command="{Binding SearchCommand}" />
              <Button Grid.Column="2" Content="Clear" Command="{Binding ClearCommand}" />
            </Grid>
            <WrapPanel>
              <Button Content="Launch" Margin="0,0,8,8" Command="{Binding LaunchCommand}" Classes="accent" />
              <Button Content="Favorite" Margin="0,0,8,8" Command="{Binding FavoriteCommand}" />
              <Button Content="Open page" Margin="0,0,8,8" Command="{Binding OpenRobloxPageCommand}" />
              <Button Content="Refresh servers" Margin="0,0,8,8" Command="{Binding RefreshServersCommand}" IsEnabled="{Binding ServersIdle}" />
              <Button Content="More servers" Margin="0,0,8,8" Command="{Binding LoadMoreServersCommand}" IsEnabled="{Binding CanLoadMoreServers}" />
            </WrapPanel>
            <TextBlock Text="{Binding Status}" Opacity="0.75" />
          </StackPanel>

          <Grid ColumnDefinitions="1.2*,1.4*" ColumnSpacing="10" RowDefinitions="*,Auto">
            <Grid Grid.Column="0" RowDefinitions="*,140" RowSpacing="8">
              <DataGrid Grid.Row="0" ItemsSource="{Binding Results}" SelectedItem="{Binding Selected}"
                        AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                  <DataGridTextColumn Header="Players" Binding="{Binding PlayerCount}" Width="70" />
                  <DataGridTextColumn Header="Creator" Binding="{Binding CreatorName}" Width="*" />
                </DataGrid.Columns>
              </DataGrid>
              <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" Text="Favorites" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox ItemsSource="{Binding Favorites}" SelectedItem="{Binding SelectedFavorite}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="alt:AltManFavoriteGame">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1" Content="×"
                                Command="{Binding $parent[UserControl].((vm:AltManViewModel)DataContext).Games.UnfavoriteCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </DockPanel>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="8">
              <Border Grid.Row="0" Padding="10" CornerRadius="6" BorderThickness="1">
                <Grid ColumnDefinitions="120,*" ColumnSpacing="12">
                  <Border Grid.Column="0" Width="120" Height="120" CornerRadius="4" ClipToBounds="True">
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding Detail.Name}" FontWeight="SemiBold" FontSize="16" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail.CreatorName}" Opacity="0.7" />
                    <TextBlock Text="{Binding Selected.PlaceId, StringFormat=Place ID: {0}}" FontFamily="Consolas" FontSize="12" />
                    <TextBlock Text="{Binding Detail.Playing, StringFormat=Playing: {0}}" />
                    <TextBlock Text="{Binding Detail.Description}" TextWrapping="Wrap" MaxHeight="72"
                               TextTrimming="CharacterEllipsis" Opacity="0.8" FontSize="12" />
                  </StackPanel>
                </Grid>
              </Border>

              <DockPanel Grid.Row="1">
                <TextBlock DockPanel.Dock="Top" Text="Servers" FontWeight="SemiBold" Margin="0,0,0,6" />
                <DataGrid ItemsSource="{Binding Servers}" AutoGenerateColumns="False" IsReadOnly="True">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Players" Binding="{Binding PlayersText}" Width="90" />
                    <DataGridTextColumn Header="Ping" Binding="{Binding PingText}" Width="90" />
                    <DataGridTextColumn Header="Region" Binding="{Binding RegionDisplay}" Width="140" />
                    <DataGridTextColumn Header="FPS" Binding="{Binding FpsText}" Width="70" />
                    <DataGridTextColumn Header="Job ID" Binding="{Binding JobId}" Width="*" />
                    <DataGridTemplateColumn Header="" Width="72">
                      <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                          <Button Content="Join"
                                  Command="{Binding $parent[UserControl].((vm:AltManViewModel)DataContext).Games.JoinServerCommand}"
                                  CommandParameter="{Binding}" />
                        </DataTemplate>
                      </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </Grid>
          </Grid>
        </DockPanel>
      </TabItem>

      <!-- History -->
      <TabItem Header="History">
        <DockPanel Margin="8" DataContext="{Binding History}">
          <StackPanel DockPanel.Dock="Top" Spacing="8">
            <WrapPanel>
              <Button Content="Refresh" Classes="accent" Margin="0,0,8,8" Command="{Binding RefreshCommand}" />
              <Button Content="Open folder" Margin="0,0,8,8" Command="{Binding OpenFolderCommand}" />
              <Button Content="Clear logs" Margin="0,0,8,8" Command="{Binding ClearLogsCommand}" />
              <Button Content="Rejoin" Margin="0,0,8,8" Command="{Binding RejoinCommand}" />
              <Button Content="Copy Place ID" Margin="0,0,8,8" Command="{Binding CopyPlaceIdCommand}" />
              <Button Content="Copy Job ID" Margin="0,0,8,8" Command="{Binding CopyJobIdCommand}" />
              <TextBox Width="200" Margin="0,0,8,8" Watermark="Search" Text="{Binding Search}" />
            </WrapPanel>
            <TextBlock Text="{Binding Status}" Opacity="0.75" />
          </StackPanel>

          <ListBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding Selected}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="alt:AltManHistorySessionRow">
                <Border Padding="8" Margin="0,0,0,6" CornerRadius="6" BorderThickness="1">
                  <Grid ColumnDefinitions="72,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Width="72" Height="72" CornerRadius="4" ClipToBounds="True">
                      <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                             RenderOptions.BitmapInterpolationMode="HighQuality" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Timestamp}" Opacity="0.65" FontSize="11" />
                      <TextBlock Text="{Binding PlaceJobLabel}" FontWeight="SemiBold" FontFamily="Consolas" FontSize="13" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding PlaceId, StringFormat=Place ID: {0}}" FontFamily="Consolas" FontSize="12" Opacity="0.85" />
                      <TextBlock Text="{Binding JobId, StringFormat=Job ID: {0}}" FontFamily="Consolas" FontSize="12" Opacity="0.85" />
                      <TextBlock Text="{Binding Server, StringFormat=Server: {0}}" FontSize="11" Opacity="0.6"
                                 IsVisible="{Binding Server, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </TabItem>

      <!-- Settings -->
      <TabItem Header="Settings">
        <ScrollViewer Margin="8" DataContext="{Binding SettingsTab}">
          <StackPanel Spacing="12" MaxWidth="640">
            <TextBlock Text="AltMan settings" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="Default account" Opacity="0.7" />
            <ComboBox ItemsSource="{Binding AccountChoices}" SelectedItem="{Binding DefaultAccount}"
                      DisplayMemberBinding="{Binding DisplayLabel}" />
            <TextBlock Text="Status refresh interval (minutes)" Opacity="0.7" />
            <NumericUpDown Minimum="1" Maximum="120" Value="{Binding StatusRefreshIntervalMinutes}" />
            <CheckBox Content="Multi Roblox (hold singleton mutex)" IsChecked="{Binding MultiRobloxEnabled}" />
            <CheckBox Content="Kill Roblox when launching" IsChecked="{Binding KillRobloxOnLaunch}" />
            <CheckBox Content="Clear Roblox cache when launching" IsChecked="{Binding ClearCacheOnLaunch}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Kill Roblox now" Command="{Binding KillRobloxNowCommand}" />
              <Button Content="Clear cache now" Command="{Binding ClearCacheNowCommand}" />
              <Button Content="Refresh console" Command="{Binding RefreshConsoleCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding Status}" Opacity="0.75" />
            <TextBlock Text="Console (AltMan-related log lines)" FontWeight="SemiBold" />
            <ListBox ItemsSource="{Binding ConsoleLines}" Height="220" FontFamily="Consolas" FontSize="11" />
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</UserControl>
