<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             xmlns:gv="clr-namespace:Froststrap.UI.ViewModels"
             x:Class="Froststrap.UI.Elements.Settings.Pages.NewsPage"
             x:DataType="vm:NewsViewModel">
  <Grid Margin="14" RowDefinitions="Auto,*">
    <TextBlock Grid.Row="0" Margin="0,0,0,10" TextWrapping="Wrap" FontSize="12.5" Opacity="0.75"
               Text="Official Roblox news from DevForum and create.roblox.com — no login required." />

    <Grid Grid.Row="1" ColumnDefinitions="*,*">
      <!-- Announcements -->
      <Border Grid.Column="0" Margin="0,0,7,0" CornerRadius="8" BorderThickness="1" Padding="0">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <Grid Grid.Row="0" Margin="14,12,14,8" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="DevForum Announcements" FontSize="15" FontWeight="SemiBold" />
              <TextBlock Text="/c/updates/announcements" FontSize="11" Opacity="0.6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Button Content="Source" Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
                      CommandParameter="{Binding AnnouncementsSourceUrl}" />
              <Button Content="Refresh" Command="{Binding RefreshAnnouncementsCommand}" />
            </StackPanel>
          </Grid>
          <TextBox Grid.Row="1" Margin="14,0,14,8" Watermark="Search announcements…"
                   Text="{Binding AnnouncementSearch}" />
          <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Announcements}" Margin="6,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AnnouncementRow">
                  <Border Margin="8,4" Padding="12,10" CornerRadius="6" BorderThickness="1">
                    <StackPanel Spacing="4">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <Button Grid.Column="0" Content="{Binding ChevronText}" Padding="4,0"
                                Command="{Binding ToggleCommand}" />
                        <TextBlock Grid.Column="1" Text="📌" Margin="0,0,6,0" IsVisible="{Binding IsPinned}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding Title}" FontWeight="SemiBold" FontSize="13.5"
                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding AgeText}" FontSize="11" Opacity="0.6"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                      </Grid>
                      <TextBlock Text="{Binding Excerpt}" TextWrapping="Wrap" FontSize="12" Opacity="0.75"
                                 Margin="28,0,0,0" MaxLines="2" TextTrimming="CharacterEllipsis"
                                 IsVisible="{Binding !IsExpanded}" />
                      <TextBlock Text="{Binding Excerpt}" TextWrapping="Wrap" FontSize="12" Opacity="0.75"
                                 Margin="28,0,0,0" IsVisible="{Binding IsExpanded}" />
                      <Button Margin="28,4,0,0" Content="Open full post" HorizontalAlignment="Left"
                              IsVisible="{Binding IsExpanded}"
                              Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
                              CommandParameter="{Binding Url}" />
                      <StackPanel Orientation="Horizontal" Spacing="14" Margin="28,4,0,0">
                        <TextBlock FontSize="11" Opacity="0.55" Text="{Binding RepliesText, StringFormat='💬 {0}'}" />
                        <TextBlock FontSize="11" Opacity="0.55" Text="{Binding ViewsText, StringFormat='👁 {0}'}" />
                        <TextBlock FontSize="11" Opacity="0.55" Text="{Binding LikesText, StringFormat='❤ {0}'}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <Grid Grid.Row="3" Margin="14,8,14,12" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding AnnouncementsFooter}" FontSize="11" Opacity="0.55"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" Text="Loading…" FontSize="11" Opacity="0.6"
                       IsVisible="{Binding AnnouncementsLoading}" />
          </Grid>
        </Grid>
      </Border>

      <!-- Release notes -->
      <Border Grid.Column="1" Margin="7,0,0,0" CornerRadius="8" BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
          <Grid Grid.Row="0" Margin="14,12,14,8" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
              <TextBlock Text="Release Notes" FontSize="15" FontWeight="SemiBold" />
              <TextBlock Text="Improvements + Fixes per release" FontSize="11" Opacity="0.6" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Button Content="Docs" Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
                      CommandParameter="{Binding ReleaseDocsUrl}" />
              <Button Content="Refresh" Command="{Binding RefreshReleaseNotesCommand}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1" Margin="14,0,14,8" ColumnDefinitions="Auto,*,Auto">
            <ComboBox Grid.Column="0" MinWidth="135" ItemsSource="{Binding Releases}"
                      SelectedItem="{Binding SelectedRelease}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding StringFormat='Release {0}'}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Content="Forum" Margin="8,0,0,0"
                    Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
                    CommandParameter="{Binding ReleaseForumUrl}" />
          </Grid>

          <Grid Grid.Row="2" Margin="14,0,14,6" ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Watermark="Search notes…" Text="{Binding ReleaseNoteSearch}" />
            <TextBlock Grid.Column="1" Text="{Binding ReleaseNotesSummary}" Margin="10,0,0,0"
                       VerticalAlignment="Center" FontSize="11" Opacity="0.55" />
          </Grid>

          <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="6" Margin="14,0,14,6">
            <ComboBox MinWidth="120" ItemsSource="{Binding TypeFilterOptions}"
                      SelectedItem="{Binding TypeFilter}" />
            <ComboBox MinWidth="100" ItemsSource="{Binding StatusFilterOptions}"
                      SelectedItem="{Binding StatusFilter}" />
            <TextBlock VerticalAlignment="Center" FontSize="11" Opacity="0.55"
                       Text="{Binding ImpCountText}" />
            <TextBlock VerticalAlignment="Center" FontSize="11" Opacity="0.55"
                       Text="{Binding FixCountText}" />
          </StackPanel>

          <ScrollViewer Grid.Row="4">
            <ItemsControl ItemsSource="{Binding ReleaseNotes}" Margin="6,0">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ReleaseNoteRow">
                  <Border Margin="8,3" Padding="10,8" CornerRadius="6" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <Border Grid.Column="0" MinWidth="34" Height="20" CornerRadius="4" Padding="5,0"
                              Margin="0,0,10,0" VerticalAlignment="Top" Background="#243FCF82">
                        <TextBlock Text="{Binding TypeBadge}" FontSize="10" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap"
                                 FontSize="12.5" VerticalAlignment="Center" />
                      <Border Grid.Column="2" CornerRadius="9" Margin="10,0,0,0" Padding="8,2"
                              VerticalAlignment="Top" IsVisible="{Binding HasStatus}">
                        <TextBlock Text="{Binding Status}" FontSize="10.5" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Grid Grid.Row="5" Margin="14,8,14,12" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding ReleaseNotesFooter}" FontSize="11" Opacity="0.55"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" Text="Loading…" FontSize="11" Opacity="0.6"
                       IsVisible="{Binding ReleaseNotesLoading}" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
