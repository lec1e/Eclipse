<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             xmlns:gv="clr-namespace:Froststrap.UI.ViewModels"
             x:Class="Froststrap.UI.Elements.Settings.Pages.AltGenPage"
             x:DataType="vm:AltGenViewModel">
  <ScrollViewer>
    <StackPanel Margin="14" Spacing="10">
      <TextBlock Text="Alt Gen" FontSize="18" FontWeight="SemiBold" />
      <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="13"
                 Text="Generate Roblox alt accounts through BloxGen using your own API key. Accounts are created and billed by BloxGen, not Eclipse." />

      <Border Padding="14,12" CornerRadius="8" BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Need a BloxGen API key?" />
            <TextBlock FontSize="12" TextWrapping="Wrap" Opacity="0.75"
                       Text="Make a free BloxGen account, grab your API key from the dashboard, then paste it below." />
          </StackPanel>
          <Button Grid.Column="1" VerticalAlignment="Center" Content="Get a free key" Classes="accent"
                  Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
                  CommandParameter="https://bloxgen.net/@osoloco98628" />
        </Grid>
      </Border>

      <Border Padding="12,8" CornerRadius="6" BorderThickness="1">
        <TextBlock FontSize="12" TextWrapping="Wrap" Opacity="0.75"
                   Text="Generated accounts come from BloxGen and are charged against your BloxGen balance. Use at your own risk. Your API key is stored only on this PC." />
      </Border>

      <TextBlock FontSize="12" Opacity="0.7" Text="Account type" />
      <ComboBox HorizontalAlignment="Left" MinWidth="300"
                ItemsSource="{Binding AltTypes}"
                SelectedItem="{Binding SelectedAltType}" />

      <TextBlock FontSize="12" Opacity="0.7" Text="Your BloxGen API key" Margin="0,8,0,0" />
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBox Grid.Column="0" FontFamily="Consolas" Text="{Binding ApiKey}"
                 Watermark="BLOX-..." />
        <Button Grid.Column="1" Margin="8,0,0,0" Content="Save key" Command="{Binding SaveKeyCommand}" />
        <Button Grid.Column="2" Margin="8,0,0,0" Content="Generate alt" Classes="accent"
                Command="{Binding GenerateCommand}" IsEnabled="{Binding CanGenerate}" />
      </Grid>

      <Border Padding="10,8" CornerRadius="6" BorderThickness="1" IsVisible="{Binding HasStatus}">
        <TextBlock TextWrapping="Wrap" FontSize="12" Text="{Binding Status}" />
      </Border>

      <Button Content="Agree to BloxGen rules" Classes="accent" HorizontalAlignment="Left"
              IsVisible="{Binding NeedsRulesAgreement}"
              Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
              CommandParameter="https://bloxgen.net/@osoloco98628" />

      <Border Padding="12,10" CornerRadius="8" BorderThickness="1" IsVisible="{Binding OnCooldown}">
        <StackPanel Spacing="6">
          <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding CooldownText}" />
          <TextBlock FontSize="12" TextWrapping="Wrap" Opacity="0.75"
                     Text="Don't want to wait? Upgrade on BloxGen for higher daily limits." />
          <Button Content="Get more generations" Classes="accent" HorizontalAlignment="Left"
                  Command="{x:Static gv:GlobalViewModel.OpenWebpageCommand}"
                  CommandParameter="https://bloxgen.net/@osoloco98628" />
        </StackPanel>
      </Border>

      <Border Padding="12,10" CornerRadius="8" BorderThickness="1" IsVisible="{Binding HasResult}">
        <StackPanel Spacing="8">
          <TextBlock FontSize="14" FontWeight="SemiBold" Text="Latest generated account" />
          <TextBlock FontSize="11" Opacity="0.6" IsVisible="{Binding HasUserId}"
                     Text="{Binding UserId, StringFormat='User ID: {0}'}" />

          <Grid ColumnDefinitions="110,*,Auto">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.7" Text="Username" />
            <TextBox Grid.Column="1" IsReadOnly="True" FontFamily="Consolas" Text="{Binding Username}" />
            <Button Grid.Column="2" Margin="6,0,0,0" Content="Copy" Command="{Binding CopyUsernameCommand}" />
          </Grid>
          <Grid ColumnDefinitions="110,*,Auto">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.7" Text="Password" />
            <TextBox Grid.Column="1" IsReadOnly="True" FontFamily="Consolas" Text="{Binding Password}"
                     PasswordChar="•" />
            <Button Grid.Column="2" Margin="6,0,0,0" Content="Copy" Command="{Binding CopyPasswordCommand}" />
          </Grid>
          <Grid ColumnDefinitions="110,*,Auto">
            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Opacity="0.7" Text=".ROBLOSECURITY" />
            <TextBox Grid.Column="1" IsReadOnly="True" FontFamily="Consolas" Text="{Binding Cookie}"
                     PasswordChar="•" />
            <Button Grid.Column="2" Margin="6,0,0,0" Content="Copy" Command="{Binding CopyCookieCommand}" />
          </Grid>

          <Button Content="Save to AltMan" Classes="accent" HorizontalAlignment="Left"
                  Command="{Binding SaveToAltManCommand}" IsEnabled="{Binding CanGenerate}" />
          <TextBlock FontSize="11" TextWrapping="Wrap" Opacity="0.55"
                     Text="Saved accounts show up on the AltMan tab, where you can launch them." />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
