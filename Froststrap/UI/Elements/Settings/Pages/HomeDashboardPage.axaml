<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             x:Class="Froststrap.UI.Elements.Settings.Pages.HomeDashboardPage"
             x:DataType="vm:HomeDashboardViewModel"
             Background="Transparent">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="26,18,22,24" Spacing="22">

      <!-- HERO + 3-METRIC STATUS (exact mockup) -->
      <Grid ColumnDefinitions="*,320" ColumnSpacing="22" MinHeight="158">
        <StackPanel VerticalAlignment="Center" Spacing="4">
          <TextBlock Text="{Binding Greeting}" FontSize="14" Foreground="#C4C9D4" />
          <TextBlock Text="{Binding DisplayName}" FontSize="44" FontWeight="Bold" Margin="0,-2,0,0">
            <TextBlock.Foreground>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#E9D5FF" Offset="0" />
                <GradientStop Color="#C084FC" Offset="0.35" />
                <GradientStop Color="#F0ABFC" Offset="0.7" />
                <GradientStop Color="#67E8F9" Offset="1" />
              </LinearGradientBrush>
            </TextBlock.Foreground>
          </TextBlock>
          <TextBlock Text="{Binding Tagline}" FontSize="13.5" Foreground="#9AA3B5"
                     TextWrapping="Wrap" MaxWidth="460" />

          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,14,0,0">
            <Button Height="42" Padding="20,0" CornerRadius="12" BorderThickness="0"
                    Command="{Binding LaunchRobloxCommand}">
              <Button.Background>
                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                  <GradientStop Color="#A78BFA" Offset="0" />
                  <GradientStop Color="#7C3AED" Offset="0.55" />
                  <GradientStop Color="#4F46E5" Offset="1" />
                </LinearGradientBrush>
              </Button.Background>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <ic:Lucide Icon="Play" Width="16" Height="16" StrokeBrush="White" />
                <TextBlock Text="Launch Roblox" FontWeight="SemiBold" Foreground="White"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Height="42" Padding="16,0" CornerRadius="12"
                    Background="#14FFFFFF" BorderBrush="#66FFFFFF" BorderThickness="1"
                    Command="{Binding OpenFolderCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <ic:Lucide Icon="Folder" Width="16" Height="16" StrokeBrush="#F1F5F9" />
                <TextBlock Text="Open Folder" Foreground="#F1F5F9" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" CornerRadius="16" Padding="16" VerticalAlignment="Center"
                Background="#AA101018" BorderBrush="#337C3AED" BorderThickness="1">
          <StackPanel Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="System Status" FontSize="14" FontWeight="SemiBold" Foreground="#F8FAFC" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Ellipse Width="7" Height="7" Fill="#34D399" VerticalAlignment="Center" />
                <TextBlock Text="All systems operational" FontSize="11" Foreground="#CBD5E1"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="*,Auto,*,Auto,*" ColumnSpacing="0">
              <StackPanel HorizontalAlignment="Center" Spacing="5">
                <ic:Lucide Icon="Wifi" Width="16" Height="16"
                           HorizontalAlignment="Center" StrokeBrush="#22D3EE" />
                <TextBlock Text="128ms" FontWeight="SemiBold" FontSize="14"
                           HorizontalAlignment="Center" Foreground="White" />
                <TextBlock Text="Latency" FontSize="10.5" Opacity="0.55"
                           HorizontalAlignment="Center" Foreground="#A1A1AA" />
              </StackPanel>
              <Border Grid.Column="1" Width="1" Height="44" Background="#28FFFFFF"
                      VerticalAlignment="Center" Margin="8,0" />
              <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="5">
                <ic:Lucide Icon="Shield" Width="16" Height="16"
                           HorizontalAlignment="Center" StrokeBrush="#A78BFA" />
                <TextBlock Text="100%" FontWeight="SemiBold" FontSize="14"
                           HorizontalAlignment="Center" Foreground="#34D399" />
                <TextBlock Text="Safe" FontSize="10.5" Opacity="0.55"
                           HorizontalAlignment="Center" Foreground="#A1A1AA" />
              </StackPanel>
              <Border Grid.Column="3" Width="1" Height="44" Background="#28FFFFFF"
                      VerticalAlignment="Center" Margin="8,0" />
              <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="5">
                <ic:Lucide Icon="Server" Width="16" Height="16"
                           HorizontalAlignment="Center" StrokeBrush="#34D399" />
                <TextBlock Text="Online" FontWeight="SemiBold" FontSize="14"
                           HorizontalAlignment="Center" Foreground="#34D399" />
                <TextBlock Text="Services" FontSize="10.5" Opacity="0.55"
                           HorizontalAlignment="Center" Foreground="#A1A1AA" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>
      </Grid>

      <!-- RECENTLY PLAYED -->
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ic:Lucide Icon="Clock" Width="16" Height="16" Opacity="0.75"
                       VerticalAlignment="Center" StrokeBrush="#CBD5E1" />
            <TextBlock Text="Recently Played" FontSize="17" FontWeight="SemiBold" Foreground="#F8FAFC" />
          </StackPanel>
          <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                  Command="{Binding OpenQuickPlayCommand}">
            <TextBlock Text="View All ›" FontSize="13" Foreground="#A78BFA" />
          </Button>
        </Grid>

        <ItemsControl ItemsSource="{Binding RecentGames}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="4" Rows="1" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:HomeGameCard">
              <Border Height="148" Margin="0,0,12,0" CornerRadius="14" ClipToBounds="True"
                      BorderBrush="#28FFFFFF" BorderThickness="1" Background="#1A0B0B12">
                <Panel>
                  <Border Background="{Binding TintBrush}" />
                  <Image Stretch="UniformToFill" IsVisible="{Binding HasImage}"
                         Source="{Binding ImageUrl, Converter={StaticResource UrlToBitmapConverter}}" />
                  <Border Background="#44000000" />
                  <Border>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="50%,25%" EndPoint="50%,100%">
                        <GradientStop Color="#00000000" Offset="0" />
                        <GradientStop Color="#F0000000" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>
                  <Grid Margin="12" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                    <StackPanel Spacing="2" Margin="0,0,8,0">
                      <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold"
                                 Foreground="White" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#B0B8C8" />
                    </StackPanel>
                    <Button Grid.Column="1" Width="32" Height="32" Padding="0" CornerRadius="16"
                            Background="#7C3AED" BorderThickness="0" VerticalAlignment="Bottom"
                            Command="{Binding $parent[UserControl].((vm:HomeDashboardViewModel)DataContext).PlayPlaceCommand}"
                            CommandParameter="{Binding PlaceId}">
                      <ic:Lucide Icon="Play" Width="13" Height="13" StrokeBrush="White"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                  </Grid>
                </Panel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <!-- FEATURED | NEWS -->
      <Grid ColumnDefinitions="1.4*,*" ColumnSpacing="14" MinHeight="250">
        <Border Grid.Column="0" Padding="16" CornerRadius="16"
                Background="#AA101018" BorderBrush="#337C3AED" BorderThickness="1">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
              <StackPanel Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <ic:Lucide Icon="Star" Width="15" Height="15" StrokeBrush="#FBBF24" VerticalAlignment="Center" />
                  <TextBlock Text="Featured" FontSize="17" FontWeight="SemiBold" Foreground="#F8FAFC" />
                </StackPanel>
                <TextBlock Text="Hand-picked experiences" FontSize="12" Foreground="#7C8499" Margin="23,0,0,0" />
              </StackPanel>
              <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                      VerticalAlignment="Top" Command="{Binding OpenQuickPlayCommand}">
                <TextBlock Text="Explore ›" FontSize="13" Foreground="#A78BFA" />
              </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding FeaturedGames}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeFeaturedItem">
                  <Border Margin="0,0,0,10" Padding="11" CornerRadius="12"
                          Background="#330B0B12" BorderBrush="#1AFFFFFF" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                      <Border Width="78" Height="52" CornerRadius="10" ClipToBounds="True" Background="#220B0B12">
                        <Panel>
                          <Border Background="{Binding TintBrush}" />
                          <Image Stretch="UniformToFill" IsVisible="{Binding HasImage}"
                                 Source="{Binding ImageUrl, Converter={StaticResource UrlToBitmapConverter}}" />
                        </Panel>
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                   Foreground="#F1F5F9" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Description}" FontSize="11.5" Foreground="#8B92A8"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <ic:Lucide Icon="ThumbsUp" Width="12" Height="12" Opacity="0.6" StrokeBrush="#CBD5E1" />
                            <TextBlock Text="{Binding Rating}" FontSize="11" Foreground="#A8B0C0" />
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <ic:Lucide Icon="Users" Width="12" Height="12" Opacity="0.6" StrokeBrush="#CBD5E1" />
                            <TextBlock Text="{Binding Players}" FontSize="11" Foreground="#A8B0C0" />
                          </StackPanel>
                        </StackPanel>
                      </StackPanel>
                      <Button Grid.Column="2" Height="32" MinWidth="70" Padding="12,0"
                              CornerRadius="9" VerticalAlignment="Center"
                              Background="Transparent" BorderBrush="#7C3AED" BorderThickness="1.5"
                              Foreground="#C4B5FD" Content="Play" FontWeight="SemiBold"
                              Command="{Binding $parent[UserControl].((vm:HomeDashboardViewModel)DataContext).PlayPlaceCommand}"
                              CommandParameter="{Binding PlaceId}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>
        </Border>

        <Border Grid.Column="1" Padding="16" CornerRadius="16"
                Background="#AA101018" BorderBrush="#337C3AED" BorderThickness="1">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <ic:Lucide Icon="Radio" Width="15" Height="15" StrokeBrush="#A78BFA" VerticalAlignment="Center" />
                <TextBlock Text="News" FontSize="17" FontWeight="SemiBold" Foreground="#F8FAFC" />
              </StackPanel>
              <TextBlock Text="Stay up to date" FontSize="12" Foreground="#7C8499" Margin="23,0,0,0" />
            </StackPanel>

            <Button DockPanel.Dock="Bottom" Margin="0,8,0,0"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    HorizontalAlignment="Left" Command="{Binding OpenNewsCommand}">
              <TextBlock Text="View All News ›" FontSize="13" Foreground="#A78BFA" />
            </Button>

            <ItemsControl ItemsSource="{Binding NewsItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeNewsItem">
                  <Border Margin="0,0,0,8" Padding="10" CornerRadius="11" Background="#280B0B12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                      <Border Width="34" Height="34" CornerRadius="9" Background="#667C3AED">
                        <ic:Lucide Icon="{Binding Icon}" Width="15" Height="15" StrokeBrush="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5"
                                   Foreground="#F1F5F9" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#8B92A8"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding When}" FontSize="11"
                                 Foreground="#6B7280" VerticalAlignment="Top" Margin="0,1,0,0" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
