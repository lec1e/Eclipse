<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             x:Class="Froststrap.UI.Elements.Settings.Pages.HomeDashboardPage"
             x:DataType="vm:HomeDashboardViewModel"
             Background="Transparent">

  <!-- One-viewport mockup composition -->
  <Grid Margin="28,18,24,22" RowDefinitions="Auto,Auto,*" RowSpacing="22">

    <!-- HERO + STATUS -->
    <Grid Grid.Row="0" ColumnDefinitions="*,270" ColumnSpacing="24" MinHeight="150">
      <StackPanel VerticalAlignment="Center" Spacing="3">
        <TextBlock Text="{Binding Greeting}" FontSize="13.5" Foreground="#AAB0C0" />
        <TextBlock Text="{Binding DisplayName}" FontSize="46" FontWeight="Bold" Margin="0,-2,0,0">
          <TextBlock.Foreground>
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#D8B4FE" Offset="0" />
              <GradientStop Color="#818CF8" Offset="0.5" />
              <GradientStop Color="#67E8F9" Offset="1" />
            </LinearGradientBrush>
          </TextBlock.Foreground>
        </TextBlock>
        <TextBlock Text="{Binding Tagline}" FontSize="13.5" Foreground="#8B92A8"
                   TextWrapping="Wrap" MaxWidth="440" Margin="0,2,0,0" />

        <StackPanel Orientation="Horizontal" Spacing="11" Margin="0,16,0,0">
          <Button Height="40" Padding="18,0" CornerRadius="11" BorderThickness="0"
                  Background="#8B5CF6" Command="{Binding LaunchRobloxCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <ic:Lucide Icon="Play" Width="15" Height="15" StrokeBrush="White" />
              <TextBlock Text="Launch Roblox" FontWeight="SemiBold" Foreground="White"
                         VerticalAlignment="Center" FontSize="13.5" />
            </StackPanel>
          </Button>
          <Button Height="40" Padding="15,0" CornerRadius="11"
                  Background="#14FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1"
                  Command="{Binding OpenFolderCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <ic:Lucide Icon="Folder" Width="15" Height="15" StrokeBrush="#E2E8F0" />
              <TextBlock Text="Open Folder" Foreground="#E2E8F0" VerticalAlignment="Center" FontSize="13.5" />
            </StackPanel>
          </Button>
        </StackPanel>
      </StackPanel>

      <Border Grid.Column="1" CornerRadius="16" Padding="16"
              Background="#99101018" BorderBrush="#338B5CF6" BorderThickness="1"
              VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="System Status" FontSize="13.5" FontWeight="SemiBold" Foreground="#F1F5F9" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Ellipse Width="7" Height="7" Fill="#34D399" VerticalAlignment="Center" />
              <TextBlock Text="All systems operational" FontSize="11" Foreground="#CBD5E1"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Grid>

          <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                  Margin="0,12,0,0" MinWidth="128" Padding="16,12" CornerRadius="14"
                  Background="#2210593A" BorderBrush="#6634D399" BorderThickness="1.5">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
              <ic:Lucide Icon="Monitor" Width="20" Height="20" StrokeBrush="#6EE7B7"
                         HorizontalAlignment="Center" />
              <TextBlock Text="128ms" FontSize="24" FontWeight="Bold" Foreground="#F0FDF4"
                         HorizontalAlignment="Center" />
              <TextBlock Text="Latency" FontSize="11" Foreground="#94A3B8"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- RECENTLY PLAYED -->
    <StackPanel Grid.Row="1" Spacing="12">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Recently Played" FontSize="17" FontWeight="SemiBold" Foreground="#F8FAFC" />
        <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                Command="{Binding OpenQuickPlayCommand}">
          <TextBlock Text="View All ›" FontSize="13" Foreground="#A78BFA" />
        </Button>
      </Grid>

      <ItemsControl ItemsSource="{Binding RecentGames}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="4" Rows="1" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:HomeGameCard">
            <Border Height="138" Margin="0,0,12,0" CornerRadius="14" ClipToBounds="True"
                    BorderBrush="#28FFFFFF" BorderThickness="1" Background="#1A0B0B12">
              <Panel>
                <!-- Fallback tint when no thumbnail -->
                <Border Background="{Binding TintBrush}" />
                <Image Stretch="UniformToFill"
                       IsVisible="{Binding HasImage}"
                       Source="{Binding ImageUrl, Converter={StaticResource UrlToBitmapConverter}}" />
                <Panel IsVisible="{Binding !HasImage}" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <ic:Lucide Icon="ImageOff" Width="28" Height="28" Opacity="0.35" StrokeBrush="White" />
                </Panel>
                <Border Background="#33000000" />
                <Border>
                  <Border.Background>
                    <LinearGradientBrush StartPoint="50%,30%" EndPoint="50%,100%">
                      <GradientStop Color="#00000000" Offset="0" />
                      <GradientStop Color="#EE000000" Offset="1" />
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>

                <Grid Margin="11" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                  <StackPanel Spacing="1" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Subtitle}" FontSize="10.5" Foreground="#B8C0D0" />
                  </StackPanel>
                  <Button Grid.Column="1" Width="30" Height="30" Padding="0" CornerRadius="15"
                          Background="#8B5CF6" BorderThickness="0" VerticalAlignment="Bottom"
                          Command="{Binding $parent[UserControl].((vm:HomeDashboardViewModel)DataContext).PlayPlaceCommand}"
                          CommandParameter="{Binding PlaceId}">
                    <ic:Lucide Icon="Play" Width="12" Height="12" StrokeBrush="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Button>
                </Grid>
              </Panel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>

    <!-- FEATURED | NEWS -->
    <Grid Grid.Row="2" ColumnDefinitions="1.45*,*" ColumnSpacing="14" MinHeight="230">
      <Border Grid.Column="0" Padding="16" CornerRadius="16"
              Background="#99101018" BorderBrush="#338B5CF6" BorderThickness="1">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <StackPanel Spacing="1">
              <TextBlock Text="Featured" FontSize="17" FontWeight="SemiBold" Foreground="#F8FAFC" />
              <TextBlock Text="Hand-picked experiences" FontSize="11.5" Foreground="#7C8499" />
            </StackPanel>
            <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                    VerticalAlignment="Top" Command="{Binding OpenQuickPlayCommand}">
              <TextBlock Text="Explore ›" FontSize="13" Foreground="#A78BFA" />
            </Button>
          </Grid>

          <ItemsControl ItemsSource="{Binding FeaturedGames}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:HomeFeaturedItem">
                <Border Margin="0,0,0,8" Padding="10" CornerRadius="12"
                        Background="#330B0B12" BorderBrush="#1AFFFFFF" BorderThickness="1">
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border Width="76" Height="50" CornerRadius="9" ClipToBounds="True" Background="#220B0B12">
                      <Panel>
                        <Border Background="{Binding TintBrush}" />
                        <Image Stretch="UniformToFill" IsVisible="{Binding HasImage}"
                               Source="{Binding ImageUrl, Converter={StaticResource UrlToBitmapConverter}}" />
                      </Panel>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                 Foreground="#F1F5F9" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#8B92A8"
                                 TextTrimming="CharacterEllipsis" />
                      <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <ic:Lucide Icon="ThumbsUp" Width="11" Height="11" Opacity="0.6" StrokeBrush="#CBD5E1" />
                          <TextBlock Text="{Binding Rating}" FontSize="11" Foreground="#A8B0C0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <ic:Lucide Icon="Users" Width="11" Height="11" Opacity="0.6" StrokeBrush="#CBD5E1" />
                          <TextBlock Text="{Binding Players}" FontSize="11" Foreground="#A8B0C0" />
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Height="32" MinWidth="68" Padding="12,0"
                            CornerRadius="9" VerticalAlignment="Center"
                            Background="Transparent" BorderBrush="#8B5CF6" BorderThickness="1.5"
                            Foreground="#C4B5FD" Content="Play" FontWeight="SemiBold"
                            Command="{Binding $parent[UserControl].((vm:HomeDashboardViewModel)DataContext).PlayPlaceCommand}"
                            CommandParameter="{Binding PlaceId}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>

      <Border Grid.Column="1" Padding="16" CornerRadius="16"
              Background="#99101018" BorderBrush="#338B5CF6" BorderThickness="1">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <StackPanel Spacing="1">
              <TextBlock Text="News" FontSize="17" FontWeight="SemiBold" Foreground="#F8FAFC" />
              <TextBlock Text="Stay up to date" FontSize="11.5" Foreground="#7C8499" />
            </StackPanel>
            <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                    VerticalAlignment="Top" Command="{Binding OpenNewsCommand}">
              <TextBlock Text="View All ›" FontSize="13" Foreground="#A78BFA" />
            </Button>
          </Grid>

          <ItemsControl ItemsSource="{Binding NewsItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:HomeNewsItem">
                <Border Margin="0,0,0,7" Padding="9" CornerRadius="11" Background="#280B0B12">
                  <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Border Width="34" Height="34" CornerRadius="9" Background="#668B5CF6">
                      <ic:Lucide Icon="{Binding Icon}" Width="15" Height="15"
                                 StrokeBrush="White"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5"
                                 Foreground="#F1F5F9" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Subtitle}" FontSize="11" Foreground="#8B92A8"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="{Binding When}" FontSize="10.5"
                               Foreground="#6B7280" VerticalAlignment="Top" Margin="0,1,0,0" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </DockPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
