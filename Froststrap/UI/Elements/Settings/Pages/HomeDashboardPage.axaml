<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
             xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
             x:Class="Froststrap.UI.Elements.Settings.Pages.HomeDashboardPage"
             x:DataType="vm:HomeDashboardViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                Padding="0,0,4,0">
    <StackPanel Margin="32,20,28,36" Spacing="28">

      <!-- HERO + STATUS -->
      <Grid ColumnDefinitions="*,280" ColumnSpacing="28">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
          <TextBlock Text="{Binding Greeting}" FontSize="14" Opacity="0.65" />
          <TextBlock Text="{Binding DisplayName}" FontSize="44" FontWeight="Bold" LetterSpacing="-0.5">
            <TextBlock.Foreground>
              <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                <GradientStop Color="#C4B5FD" Offset="0" />
                <GradientStop Color="#818CF8" Offset="0.4" />
                <GradientStop Color="#67E8F9" Offset="1" />
              </LinearGradientBrush>
            </TextBlock.Foreground>
          </TextBlock>
          <TextBlock Text="{Binding Tagline}" FontSize="13.5" Opacity="0.62" TextWrapping="Wrap" MaxWidth="420" Margin="0,2,0,0" />

          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,18,0,0">
            <Button Height="42" Padding="20,0" CornerRadius="12" BorderThickness="0"
                    Background="#7C3AED" Command="{Binding LaunchRobloxCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <ic:Lucide Icon="Play" Width="16" Height="16" StrokeBrush="White" />
                <TextBlock Text="Launch Roblox" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Height="42" Padding="16,0" CornerRadius="12"
                    Background="#12FFFFFF" BorderBrush="#40FFFFFF" BorderThickness="1"
                    Command="{Binding OpenFolderCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <ic:Lucide Icon="Folder" Width="16" Height="16" Opacity="0.9" />
                <TextBlock Text="Open Folder" VerticalAlignment="Center" Opacity="0.95" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>

        <!-- Single latency card (mockup) -->
        <Border Grid.Column="1" Padding="18" CornerRadius="18" MinHeight="148"
                VerticalAlignment="Stretch"
                Background="#AA0E0D16" BorderBrush="#2EA78BFA" BorderThickness="1">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="System Status" FontSize="14" FontWeight="SemiBold" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Ellipse Width="7" Height="7" Fill="#34D399" />
                <TextBlock Text="All systems operational" FontSize="11" Opacity="0.8" />
              </StackPanel>
            </Grid>

            <Border Grid.Row="1" Margin="0,14,0,0" CornerRadius="14" Padding="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#2210B981" BorderBrush="#5534D399" BorderThickness="1"
                    MinWidth="120">
              <StackPanel Spacing="6" HorizontalAlignment="Center">
                <ic:Lucide Icon="Monitor" Width="22" Height="22" Opacity="0.85"
                           HorizontalAlignment="Center" StrokeBrush="#6EE7B7" />
                <TextBlock Text="128ms" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#ECFDF5" />
                <TextBlock Text="Latency" FontSize="11" Opacity="0.7"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <!-- RECENTLY PLAYED -->
      <StackPanel Spacing="14">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Recently Played" FontSize="18" FontWeight="SemiBold" />
          <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                  Command="{Binding OpenQuickPlayCommand}">
            <TextBlock Text="View All ›" FontSize="13" Foreground="#A78BFA" />
          </Button>
        </Grid>

        <ItemsControl ItemsSource="{Binding RecentGames}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="4" Rows="1" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:HomeGameCard">
              <Border Height="152" Margin="0,0,14,0" CornerRadius="16" ClipToBounds="True"
                      BorderBrush="#28FFFFFF" BorderThickness="1" Background="#180B0A12">
                <Panel>
                  <Image Stretch="UniformToFill"
                         Source="{Binding ImageUrl, Converter={StaticResource UrlToBitmapConverter}}" />
                  <!-- tinted overlay like mockup -->
                  <Border Background="#55000000" />
                  <Border>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="50%,35%" EndPoint="50%,100%">
                        <GradientStop Color="#00000000" Offset="0" />
                        <GradientStop Color="#E6000000" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>

                  <Grid Margin="12" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                    <StackPanel Spacing="2" VerticalAlignment="Bottom" Margin="0,0,8,0">
                      <TextBlock Text="{Binding Name}" FontSize="13.5" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.72" />
                    </StackPanel>
                    <Button Grid.Column="1" Width="32" Height="32" Padding="0"
                            VerticalAlignment="Bottom" CornerRadius="16"
                            Background="#7C3AED" BorderThickness="0"
                            Command="{Binding $parent[UserControl].((vm:HomeDashboardViewModel)DataContext).PlayPlaceCommand}"
                            CommandParameter="{Binding PlaceId}">
                      <ic:Lucide Icon="Play" Width="13" Height="13" StrokeBrush="White"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                  </Grid>
                </Panel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <!-- FEATURED | NEWS -->
      <Grid ColumnDefinitions="1.4*,*" ColumnSpacing="16" MinHeight="248">
        <Border Grid.Column="0" Padding="18" CornerRadius="18"
                Background="#990E0D16" BorderBrush="#2EA78BFA" BorderThickness="1">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
              <StackPanel Spacing="2">
                <TextBlock Text="Featured" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Hand-picked experiences" FontSize="12" Opacity="0.5" />
              </StackPanel>
              <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                      VerticalAlignment="Top" Command="{Binding OpenQuickPlayCommand}">
                <TextBlock Text="Explore ›" FontSize="13" Foreground="#A78BFA" />
              </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding FeaturedGames}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeFeaturedItem">
                  <Border Margin="0,0,0,10" Padding="12" CornerRadius="14"
                          Background="#330B0A14" BorderBrush="#18FFFFFF" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                      <Border Width="78" Height="52" CornerRadius="10" ClipToBounds="True" Background="#220E0D16">
                        <Image Stretch="UniformToFill"
                               Source="{Binding ImageUrl, Converter={StaticResource UrlToBitmapConverter}}" />
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Description}" FontSize="11.5" Opacity="0.55"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,2,0,0">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <ic:Lucide Icon="ThumbsUp" Width="12" Height="12" Opacity="0.55" />
                            <TextBlock Text="{Binding Rating}" FontSize="11" Opacity="0.7" />
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <ic:Lucide Icon="Users" Width="12" Height="12" Opacity="0.55" />
                            <TextBlock Text="{Binding Players}" FontSize="11" Opacity="0.7" />
                          </StackPanel>
                        </StackPanel>
                      </StackPanel>
                      <Button Grid.Column="2" Height="34" MinWidth="72" Padding="14,0"
                              CornerRadius="10" VerticalAlignment="Center"
                              Background="Transparent" BorderBrush="#8B5CF6" BorderThickness="1.5"
                              Foreground="#C4B5FD" Content="Play"
                              Command="{Binding $parent[UserControl].((vm:HomeDashboardViewModel)DataContext).PlayPlaceCommand}"
                              CommandParameter="{Binding PlaceId}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>
        </Border>

        <Border Grid.Column="1" Padding="18" CornerRadius="18"
                Background="#990E0D16" BorderBrush="#2EA78BFA" BorderThickness="1">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
              <StackPanel Spacing="2">
                <TextBlock Text="News" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="Stay up to date" FontSize="12" Opacity="0.5" />
              </StackPanel>
              <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0"
                      VerticalAlignment="Top" Command="{Binding OpenNewsCommand}">
                <TextBlock Text="View All ›" FontSize="13" Foreground="#A78BFA" />
              </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding NewsItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:HomeNewsItem">
                  <Border Margin="0,0,0,8" Padding="10,10" CornerRadius="12" Background="#280B0A14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                      <Border Width="36" Height="36" CornerRadius="10" Background="#557C3AED">
                        <ic:Lucide Icon="{Binding Icon}" Width="16" Height="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   StrokeBrush="White" />
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Subtitle}" FontSize="11.5" Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding When}" FontSize="11" Opacity="0.45"
                                 VerticalAlignment="Top" Margin="4,2,0,0" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
