<base:AvaloniaWindow
    x:Class="Froststrap.UI.Elements.Settings.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:elements="clr-namespace:Froststrap.UI.Elements"
    xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
    xmlns:local="clr-namespace:Froststrap.UI.Elements.Settings"
    xmlns:enums="using:Froststrap.Enums"
    xmlns:resources="using:Froststrap.Resources"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
    Title="{x:Static resources:Strings.Menu_Title}"
    Width="1200"
    Height="760"
    MinWidth="900"
    MinHeight="520"
    x:DataType="vm:MainWindowViewModel"
    CanResize="True"
    WindowStartupLocation="CenterScreen">

    <Grid Background="#08070E" ColumnDefinitions="236,*" RowDefinitions="48,*,64">
        <controls:AnimatedAuroraBackground
            x:Name="AuroraBackground"
            Grid.Row="0" Grid.RowSpan="3"
            Grid.Column="0" Grid.ColumnSpan="2"
            ZIndex="0" />

        <!-- Labeled left sidebar (mockup-style) -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" ZIndex="1"
                Background="#CC0B0A12"
                BorderBrush="#33A855F7"
                BorderThickness="0,0,1,0"
                Padding="18,16,14,16">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Brand -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="4,4,4,20">
                    <Image Width="32" Height="32" Source="avares://Eclipse/Eclipse.png"
                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                    <TextBlock Text="Eclipse"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="White" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="RailItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:RailNavItem">
                                <Panel IsVisible="{Binding IsVisible}">
                                    <Border Height="1"
                                            Margin="8,10"
                                            Background="#33FFFFFF"
                                            IsVisible="{Binding IsSeparator}" />
                                    <Button Classes="rail-labeled"
                                            Height="42"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="8,0"
                                            ToolTip.Tip="{Binding Title}"
                                            Tag="{Binding Tag}"
                                            IsEnabled="{Binding IsEnabled}"
                                            IsVisible="{Binding !IsSeparator}"
                                            Click="RailItem_Click">
                                        <Panel>
                                            <Border CornerRadius="12"
                                                    Background="#44A855F7"
                                                    IsVisible="{Binding IsSelected}" />
                                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,0">
                                                <Border Width="3" Height="20" CornerRadius="2"
                                                        Background="{DynamicResource BrandAccentBrush}"
                                                        Margin="0,0,10,0"
                                                        IsVisible="{Binding IsSelected}" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                                                            VerticalAlignment="Center">
                                                    <ic:Lucide Icon="{Binding Icon}" Width="18" Height="18" />
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                        </Panel>
                                    </Button>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Online + version -->
                <StackPanel Grid.Row="2" Spacing="6" Margin="8,16,8,4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="#34D399" VerticalAlignment="Center" />
                        <TextBlock Text="Online" FontSize="12" Opacity="0.85" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding VersionText}" FontSize="11" Opacity="0.45" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top search bar -->
        <Border Grid.Row="0" Grid.Column="1" ZIndex="1"
                Background="#660B0A12"
                BorderBrush="#22FFFFFF"
                BorderThickness="0,0,0,1">
            <controls:TitleBar Title="" ShowMinimize="True" ShowMaximize="True">
                <elements:SearchBar Width="420" DataContext="{Binding SearchBar}" />
            </controls:TitleBar>
        </Border>

        <!-- Floating content (no heavy glass cage) -->
        <Grid Grid.Row="1" Grid.Column="1" ZIndex="1" Margin="24,16,24,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,12"
                        IsVisible="{Binding ShowPageChrome}">
                <ItemsControl
                    Margin="0,0,0,8"
                    IsVisible="{Binding HasBreadcrumbs}"
                    ItemsSource="{Binding BreadcrumbItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:BreadcrumbItemModel">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Padding="0" Background="Transparent" BorderThickness="0"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbItemClickedCommand}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding Content}"
                                        FontSize="18" FontWeight="SemiBold"
                                        IsVisible="{Binding !IsLast}" />
                                <TextBlock Text="›" FontSize="18" Opacity="0.5" IsVisible="{Binding !IsLast}" />
                                <TextBlock Text="{Binding Content}" FontSize="18" FontWeight="SemiBold" IsVisible="{Binding IsLast}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="PageTitleText"
                           FontSize="22" FontWeight="SemiBold"
                           IsVisible="{Binding ShowPageTitle}"
                           Text="{Binding CurrentPageTitle}" />
                <controls:MarkdownTextBlock x:Name="PageDescriptionText"
                                            Margin="0,4,0,0"
                                            FontSize="13" Opacity="0.7"
                                            IsVisible="{Binding CurrentPageDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            MarkdownText="{Binding CurrentPageDescription}" />
                <ui:FAInfoBar x:Name="AlertBar" Margin="0,8,0,0" IsVisible="False" Severity="Warning" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,0">
                <TransitioningContentControl
                    x:Name="PageContentControl"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" />
            </Border>
        </Grid>

        <!-- Footer actions -->
        <Border Grid.Row="2" Grid.Column="1" ZIndex="1"
                Margin="24,0,24,12"
                Padding="10,0,12,0"
                CornerRadius="14"
                Background="#990B0A12"
                BorderBrush="#28A855F7"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <local:AccountSelectorView x:Name="AccountSelectorView" Grid.Column="0" />
                <controls:IconButton Grid.Column="2"
                                     Height="36" Padding="20,0"
                                     Classes="DropDownButton Primary"
                                     Command="{Binding SaveAndLaunchSettingsCommand}"
                                     Content="{Binding LaunchButtonText}">
                    <controls:IconButton.Flyout>
                        <MenuFlyout Placement="TopEdgeAlignedRight">
                            <MenuItem Header="{Binding PlayerMenuItemText}" Command="{Binding SetLaunchModeCommand}"
                                      CommandParameter="{x:Static enums:LaunchMode.Player}">
                                <MenuItem.Icon><ic:Lucide Icon="Gamepad2" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{x:Static resources:Strings.Common_Studio}" Command="{Binding SetLaunchModeCommand}"
                                      CommandParameter="{x:Static enums:LaunchMode.Studio}">
                                <MenuItem.Icon><ic:Lucide Icon="Wrench" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </controls:IconButton.Flyout>
                </controls:IconButton>
                <Button Grid.Column="3" Height="36" Padding="20,0" Classes="accent"
                        Command="{Binding RestartAppCommand}" Content="{x:Static resources:Strings.Menu_Restart}" />
                <Button Grid.Column="4" Height="36" Padding="20,0" Classes="accent"
                        Command="{Binding SaveSettingsCommand}" Content="{x:Static resources:Strings.Menu_Save}" />
                <Button Grid.Column="5" Height="36" Padding="20,0"
                        Command="{Binding CloseWindowCommand}" Content="{x:Static resources:Strings.Common_Close}" />
            </Grid>
        </Border>

        <Panel Name="NotificationPanel"
               Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="2"
               Margin="0,0,0,15" VerticalAlignment="Bottom" ZIndex="1000" />

        <Border x:Name="OffscreenIndexingCanvas"
                Grid.Row="1" Grid.Column="1"
                Width="905" Height="700"
                IsHitTestVisible="False" IsVisible="False" Opacity="0" ZIndex="-1000" />
    </Grid>
</base:AvaloniaWindow>
