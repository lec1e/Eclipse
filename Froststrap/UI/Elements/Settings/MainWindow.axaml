<base:AvaloniaWindow
    x:Class="Froststrap.UI.Elements.Settings.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:elements="clr-namespace:Froststrap.UI.Elements"
    xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
    xmlns:local="clr-namespace:Froststrap.UI.Elements.Settings"
    xmlns:enums="using:Froststrap.Enums"
    xmlns:resources="using:Froststrap.Resources"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
    Title="{x:Static resources:Strings.Menu_Title}"
    Width="1125"
    Height="700"
    MinWidth="750"
    MinHeight="415"
    x:DataType="vm:MainWindowViewModel"
    CanResize="True"
    WindowStartupLocation="CenterScreen">

    <Grid Background="{DynamicResource BrandInkBrush}" RowDefinitions="48,*,56">
        <controls:AnimatedAuroraBackground
            x:Name="AuroraBackground"
            Grid.Row="0" Grid.RowSpan="3"
            ZIndex="0" />

        <!-- Title bar -->
        <Border Grid.Row="0" ZIndex="1"
                Background="{DynamicResource GlassHeaderBrush}"
                BorderBrush="{DynamicResource BrandHairlineBrush}"
                BorderThickness="0,0,0,1">
            <controls:TitleBar
                Title="Eclipse"
                Icon="avares://Eclipse/Eclipse.png">
                <elements:SearchBar Width="400" DataContext="{Binding SearchBar}" />
            </controls:TitleBar>
        </Border>

        <!-- Midnight rail + glass stage -->
        <Grid Grid.Row="1" ZIndex="1" ColumnDefinitions="72,*" Margin="10,10,10,0">
            <!-- Icon rail -->
            <Border Grid.Column="0"
                    Width="64"
                    Margin="0,0,10,0"
                    CornerRadius="16"
                    Background="{DynamicResource GlassRailBrush}"
                    BorderBrush="{DynamicResource BrandHairlineBrush}"
                    BorderThickness="1"
                    Padding="6,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="RailItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:RailNavItem">
                                <Panel IsVisible="{Binding IsVisible}">
                                    <Border Height="1"
                                            Margin="10,6"
                                            Background="{DynamicResource BrandHairlineBrush}"
                                            IsVisible="{Binding IsSeparator}"
                                            Opacity="0.7" />
                                    <Button Classes="rail"
                                            Width="48" Height="48"
                                            Padding="0"
                                            HorizontalAlignment="Center"
                                            ToolTip.Tip="{Binding Title}"
                                            Tag="{Binding Tag}"
                                            IsEnabled="{Binding IsEnabled}"
                                            IsVisible="{Binding !IsSeparator}"
                                            Click="RailItem_Click">
                                        <Panel Width="48" Height="48">
                                            <Border CornerRadius="12"
                                                    Background="#33C084FC"
                                                    IsVisible="{Binding IsSelected}" />
                                            <Border Classes="rail-indicator"
                                                    Width="3" Height="22"
                                                    CornerRadius="2"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Margin="2,0,0,0"
                                                    Background="{DynamicResource BrandAccentBrush}"
                                                    IsVisible="{Binding IsSelected}" />
                                            <ic:Lucide Icon="{Binding Icon}"
                                                       Width="22" Height="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Panel>
                                    </Button>
                                </Panel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Glass content stage -->
            <Border Grid.Column="1"
                    CornerRadius="16"
                    Background="{DynamicResource GlassStageBrush}"
                    BorderBrush="{DynamicResource BrandHairlineBrush}"
                    BorderThickness="1"
                    ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border
                        Grid.Row="0"
                        Padding="22,20,22,14"
                        BorderThickness="0,0,0,1"
                        Background="{DynamicResource GlassHeaderBrush}"
                        BorderBrush="{DynamicResource BrandHairlineBrush}">
                        <StackPanel>
                            <ItemsControl
                                Margin="0,0,0,10"
                                IsVisible="{Binding HasBreadcrumbs}"
                                ItemsSource="{Binding BreadcrumbItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:BreadcrumbItemModel">
                                        <StackPanel
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                            <Button
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbItemClickedCommand}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding Content}"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                IsVisible="{Binding !IsLast}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="20"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                IsVisible="{Binding !IsLast}"
                                                Text="›" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="20"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                IsVisible="{Binding IsLast}"
                                                Text="{Binding Content}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                x:Name="PageTitleText"
                                Margin="0,0,0,4"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                IsVisible="{Binding ShowPageTitle}"
                                Text="{Binding CurrentPageTitle}" />

                            <controls:MarkdownTextBlock
                                x:Name="PageDescriptionText"
                                Margin="0,0,0,2"
                                FontSize="13"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                IsVisible="{Binding CurrentPageDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                MarkdownText="{Binding CurrentPageDescription}" />

                            <ui:FAInfoBar
                                x:Name="AlertBar"
                                Margin="0,8,0,0"
                                IsVisible="False"
                                Severity="Warning" />
                        </StackPanel>
                    </Border>

                    <Panel Grid.Row="1">
                        <TransitioningContentControl
                            x:Name="PageContentControl"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                    </Panel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border
            Grid.Row="2"
            ZIndex="1"
            Height="56"
            Margin="10,8,10,8"
            Padding="8,0,12,0"
            CornerRadius="14"
            Background="{DynamicResource GlassHeaderBrush}"
            BorderBrush="{DynamicResource BrandHairlineBrush}"
            BorderThickness="1">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto" ColumnSpacing="8">
                <local:AccountSelectorView
                    x:Name="AccountSelectorView"
                    Grid.Column="0" />
                <controls:IconButton Grid.Column="2"
                                     Height="36"
                                     Padding="20,0"
                                     Classes="DropDownButton Primary"
                                     Command="{Binding SaveAndLaunchSettingsCommand}"
                                     Content="{Binding LaunchButtonText}">
                    <controls:IconButton.Flyout>
                        <MenuFlyout Placement="TopEdgeAlignedRight">
                            <MenuItem Header="{Binding PlayerMenuItemText}" Command="{Binding SetLaunchModeCommand}"
                                      CommandParameter="{x:Static enums:LaunchMode.Player}">
                                <MenuItem.Icon>
                                    <ic:Lucide Icon="Gamepad2" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{x:Static resources:Strings.Common_Studio}" Command="{Binding SetLaunchModeCommand}"
                                      CommandParameter="{x:Static enums:LaunchMode.Studio}">
                                <MenuItem.Icon>
                                    <ic:Lucide Icon="Wrench" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </controls:IconButton.Flyout>
                </controls:IconButton>
                <Button
                    Grid.Column="3"
                    Height="36"
                    Padding="20,0"
                    Classes="accent"
                    Command="{Binding RestartAppCommand}"
                    Content="{x:Static resources:Strings.Menu_Restart}" />
                <Button
                    Grid.Column="4"
                    Height="36"
                    Padding="20,0"
                    Classes="accent"
                    Command="{Binding SaveSettingsCommand}"
                    Content="{x:Static resources:Strings.Menu_Save}" />
                <Button
                    Grid.Column="5"
                    Height="36"
                    Padding="20,0"
                    Command="{Binding CloseWindowCommand}"
                    Content="{x:Static resources:Strings.Common_Close}" />
            </Grid>
        </Border>

        <Panel
            Name="NotificationPanel"
            Grid.Row="0"
            Grid.RowSpan="3"
            Margin="0,0,0,15"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            ZIndex="1000" />

        <Border
            x:Name="OffscreenIndexingCanvas"
            Grid.Row="1"
            Width="905"
            Height="700"
            IsHitTestVisible="False"
            IsVisible="False"
            Opacity="0"
            ZIndex="-1000" />
    </Grid>
</base:AvaloniaWindow>
