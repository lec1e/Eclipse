<base:AvaloniaWindow
    x:Class="Froststrap.UI.Elements.Settings.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Froststrap.UI.Elements.Base"
    xmlns:controls="clr-namespace:Froststrap.UI.Elements.Controls"
    xmlns:elements="clr-namespace:Froststrap.UI.Elements"
    xmlns:ic="clr-namespace:LucideAvalonia;assembly=LucideAvalonia"
    xmlns:local="clr-namespace:Froststrap.UI.Elements.Settings"
    xmlns:enums="using:Froststrap.Enums"
    xmlns:resources="using:Froststrap.Resources"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Settings"
    Title="{x:Static resources:Strings.Menu_Title}"
    Width="1280"
    Height="800"
    MinWidth="1080"
    MinHeight="680"
    x:DataType="vm:MainWindowViewModel"
    CanResize="True"
    WindowStartupLocation="CenterScreen"
    Background="#030306">

    <Grid RowDefinitions="52,*,Auto">
        <controls:AnimatedAuroraBackground
            x:Name="AuroraBackground"
            Grid.Row="0" Grid.RowSpan="3"
            ZIndex="0" />

        <!-- TOP BAR (full width) -->
        <Border Grid.Row="0" ZIndex="3"
                Background="#9906060A"
                BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="52">
                <Panel Grid.Column="0" Grid.ColumnSpan="3"
                       WindowDecorationProperties.ElementRole="TitleBar"
                       Background="Transparent" />

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center" Margin="16,0,12,0" IsHitTestVisible="False">
                    <!-- Solar eclipse mark (dark disc + purple crescent) -->
                    <controls:EclipseLogoMark Width="28" Height="28" />
                    <TextBlock Text="Eclipse" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#F8FAFC" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="560" Height="36"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        CornerRadius="10"
                        Background="#2E12121A"
                        BorderBrush="#28FFFFFF" BorderThickness="1"
                        Padding="2,0,8,0">
                    <Grid ColumnDefinitions="*,Auto">
                        <elements:SearchBar DataContext="{Binding SearchBar}"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center" />
                        <Border Grid.Column="1" Padding="7,2" CornerRadius="5"
                                Background="#1AFFFFFF" VerticalAlignment="Center">
                            <TextBlock Text="Ctrl K" FontSize="10.5" Foreground="#88FFFFFF" />
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <controls:IconButton Classes="TitleBarButton" Icon="Download"
                                         ToolTip.Tip="Deployment" Click="TopDownload_Click" />
                    <controls:IconButton Classes="TitleBarButton" Icon="Bell"
                                         ToolTip.Tip="News" Click="TopNews_Click" />
                    <controls:IconButton Name="PART_MinimizeButton" Classes="TitleBarButton" Icon="Minus" />
                    <controls:IconButton Name="PART_MaximizeButton" Classes="TitleBarButton" Icon="Maximize" />
                    <controls:IconButton Name="PART_CloseButton" Classes="TitleBarButton Close" Icon="X" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY: icon rail + stage -->
        <Grid Grid.Row="1" ZIndex="1" ColumnDefinitions="78,*">
            <Border Grid.Column="0"
                    Background="#6606060A"
                    BorderBrush="#0CFFFFFF" BorderThickness="0,0,1,0"
                    Padding="8,14,8,12">
                <Grid RowDefinitions="*,Auto">
                    <ItemsControl x:Name="RailItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:RailNavItem">
                                <Button Classes="rail-icon"
                                        Width="62" Height="58"
                                        HorizontalAlignment="Center"
                                        Padding="0"
                                        Tag="{Binding Tag}"
                                        ToolTip.Tip="{Binding Title}"
                                        Click="RailItem_Click">
                                    <Panel Width="56" Height="54">
                                        <!-- Soft purple selected pad (mockup) -->
                                        <Border CornerRadius="12" IsVisible="{Binding IsSelected}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                    <GradientStop Color="#AA8B5CF6" Offset="0" />
                                                    <GradientStop Color="#886D28D9" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <ic:Lucide Icon="{Binding Icon}" Width="20" Height="20"
                                                       HorizontalAlignment="Center" StrokeBrush="White" />
                                            <TextBlock Text="{Binding Title}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#E8EDF5"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Panel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="1" Spacing="4" HorizontalAlignment="Center" Margin="0,12,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                            <Ellipse Width="7" Height="7" Fill="#34D399" VerticalAlignment="Center" />
                            <TextBlock Text="Online" FontSize="11" Foreground="#D1D5DB" />
                        </StackPanel>
                        <TextBlock Text="{Binding VersionText}" FontSize="10"
                                   Foreground="#66FFFFFF" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Open content on aurora (no stage card — matches mockup) -->
            <Grid Grid.Column="1" Margin="8,4,8,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="20,12,20,0" IsVisible="{Binding ShowPageChrome}">
                    <ItemsControl IsVisible="{Binding HasBreadcrumbs}" ItemsSource="{Binding BreadcrumbItems}" Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:BreadcrumbItemModel">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Padding="0" Background="Transparent" BorderThickness="0"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BreadcrumbItemClickedCommand}"
                                            CommandParameter="{Binding}" Content="{Binding Content}"
                                            FontSize="18" FontWeight="SemiBold" IsVisible="{Binding !IsLast}" />
                                    <TextBlock Text="›" FontSize="18" Opacity="0.5" IsVisible="{Binding !IsLast}" />
                                    <TextBlock Text="{Binding Content}" FontSize="18" FontWeight="SemiBold" IsVisible="{Binding IsLast}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="PageTitleText" FontSize="22" FontWeight="SemiBold"
                               IsVisible="{Binding ShowPageTitle}" Text="{Binding CurrentPageTitle}" />
                    <controls:MarkdownTextBlock x:Name="PageDescriptionText" Margin="0,4,0,0"
                                                FontSize="13" Opacity="0.7"
                                                IsVisible="{Binding CurrentPageDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                MarkdownText="{Binding CurrentPageDescription}" />
                    <ui:FAInfoBar x:Name="AlertBar" Margin="0,8,0,0" IsVisible="False" Severity="Warning" />
                </StackPanel>

                <TransitioningContentControl Grid.Row="1" x:Name="PageContentControl"
                                             HorizontalAlignment="Stretch"
                                             VerticalAlignment="Stretch" />
            </Grid>
        </Grid>

        <Border Grid.Row="2" ZIndex="2"
                IsVisible="{Binding ShowFooter}"
                Margin="88,0,16,12" Padding="10,0,12,0" Height="50"
                CornerRadius="14" Background="#99050508"
                BorderBrush="#447C3AED" BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <local:AccountSelectorView x:Name="AccountSelectorView" Grid.Column="0" />
                <controls:IconButton Grid.Column="2" Height="36" Padding="20,0"
                                     Classes="DropDownButton Primary"
                                     Command="{Binding SaveAndLaunchSettingsCommand}"
                                     Content="{Binding LaunchButtonText}">
                    <controls:IconButton.Flyout>
                        <MenuFlyout Placement="TopEdgeAlignedRight">
                            <MenuItem Header="{Binding PlayerMenuItemText}" Command="{Binding SetLaunchModeCommand}"
                                      CommandParameter="{x:Static enums:LaunchMode.Player}">
                                <MenuItem.Icon><ic:Lucide Icon="Gamepad2" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{x:Static resources:Strings.Common_Studio}" Command="{Binding SetLaunchModeCommand}"
                                      CommandParameter="{x:Static enums:LaunchMode.Studio}">
                                <MenuItem.Icon><ic:Lucide Icon="Wrench" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </controls:IconButton.Flyout>
                </controls:IconButton>
                <Button Grid.Column="3" Height="36" Padding="20,0" Classes="accent"
                        Command="{Binding RestartAppCommand}" Content="{x:Static resources:Strings.Menu_Restart}" />
                <Button Grid.Column="4" Height="36" Padding="20,0" Classes="accent"
                        Command="{Binding SaveSettingsCommand}" Content="{x:Static resources:Strings.Menu_Save}" />
                <Button Grid.Column="5" Height="36" Padding="20,0"
                        Command="{Binding CloseWindowCommand}" Content="{x:Static resources:Strings.Common_Close}" />
            </Grid>
        </Border>

        <Panel Name="NotificationPanel"
               Grid.Row="0" Grid.RowSpan="3"
               Margin="0,0,0,15" VerticalAlignment="Bottom" ZIndex="1000" />

        <Border x:Name="OffscreenIndexingCanvas"
                Grid.Row="1"
                Width="905" Height="700"
                IsHitTestVisible="False" IsVisible="False" Opacity="0" ZIndex="-1000" />
    </Grid>
</base:AvaloniaWindow>
