<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Dialogs"
        x:Class="Froststrap.UI.Elements.Dialogs.VersionPickerDialog"
        x:DataType="vm:VersionPickerViewModel"
        Title="Pick a version profile"
        Width="420" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <TextBlock Text="Which profile should launch?" FontWeight="SemiBold" FontSize="16" />
        <ListBox Grid.Row="1" Margin="0,12,0,12" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,4">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding VersionGuid}" FontFamily="Consolas" FontSize="11" Opacity="0.7"
                                   IsVisible="{Binding VersionGuid, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="Latest LIVE" FontSize="11" Opacity="0.7"
                                   IsVisible="{Binding VersionGuid, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="Cancel_Click" />
            <Button Content="Launch" Classes="accent" Click="Launch_Click" />
        </StackPanel>
    </Grid>
</Window>
