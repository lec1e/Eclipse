<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Froststrap.UI.ViewModels.Dialogs"
        x:Class="Froststrap.UI.Elements.Dialogs.AddVersionProfileDialog"
        x:DataType="vm:AddVersionProfileViewModel"
        Title="Add version profile"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <StackPanel Spacing="8">
            <TextBlock Text="Create a Versions Manager profile" FontWeight="SemiBold" FontSize="16" />
            <TextBox Watermark="Profile name" Text="{Binding ProfileName}" />
            <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" HorizontalAlignment="Stretch" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="8" IsVisible="{Binding IsExecutorMode}">
            <TextBlock Text="Pick an executor from WEAO" Opacity="0.7" />
            <Button Content="Load executors" Command="{Binding LoadExecutorsCommand}" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Opacity="0.7" />
            <ListBox ItemsSource="{Binding Exploits}" SelectedItem="{Binding SelectedExploit}" MaxHeight="240">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RbxVersion}" FontFamily="Consolas" FontSize="11" Opacity="0.7" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="8" IsVisible="{Binding IsManualMode}">
            <TextBlock Text="Paste a version-xxxxxxxxxxxxxxxx hash" Opacity="0.7" />
            <TextBox Watermark="version-…" Text="{Binding ManualVersionGuid}" FontFamily="Consolas" />
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Opacity="0.7" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="Cancel_Click" />
            <Button Content="Add" Classes="accent" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
